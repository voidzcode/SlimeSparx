{
  "manifest_version": 3,
  "name": "SlimeSparx",
  "version": "1.2",
  "description": "Text selection fix for Sparx Reader with Gemini and AI Commands integration.",
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://sites.google.com/*",
    "https://*.sparxreader.co.uk/*",
    "https://*.sparx-learning.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.sparxreader.co.uk/*",
        "https://*.sparx-learning.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}